# ─────────────────────────────────────────────────────────────
# FitCraft Backend — Environment Variables Template
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────
# Local MongoDB (used when running without Docker)
MONGO_URI=mongodb://localhost:27017/fitcraft
# MongoDB Atlas (cloud — uncomment and replace for production)
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fitcraft?retryWrites=true&w=majority

# ── Authentication ─────────────────────────────────────────────
# IMPORTANT: Change JWT_SECRET to a long, random string in production!
JWT_SECRET=fitcraft_jwt
JWT_EXPIRES_IN=7d

# ── Frontend URL (CORS) ────────────────────────────────────────
# Local dev frontend URL
CLIENT_URL=http://localhost:5173
# Production frontend URL (update when deploying)
# CLIENT_URL=https://yourdomain.com

# ── Razorpay Payments ────────────────────────────────────────────────────────
# Get keys from https://dashboard.razorpay.com/app/keys
# Use rzp_test_* keys for development, rzp_live_* for production
# Leave blank to run in MOCK mode (no real payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Cloudinary (Image Storage) ─────────────────────────────────
# Get credentials from https://cloudinary.com/console
# Leave blank to store images locally in /uploads folder
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email Notifications ────────────────────────────────────────
# Option 1: SendGrid — https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com

# Option 2: SMTP (Gmail, Outlook, etc.)
# Fill these in if you prefer SMTP over SendGrid
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── ngrok (Local Tunnel for Stripe Webhooks) ───────────────────
# Get token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
